    // Helper method to convert HEX to RGB for CSS variables
    private string HexToRgb(string hex)
    {
        if (string.IsNullOrEmpty(hex))
            return "145, 0, 18"; // Default fallback
            
        hex = hex.Replace("#", "");
        
        // Handle rgba() format
        if (hex.StartsWith("rgba("))
        {
            var parts = hex.Replace("rgba(", "").Replace(")", "").Split(',');
            if (parts.Length >= 3)
                return $"{parts[0].Trim()}, {parts[1].Trim()}, {parts[2].Trim()}";
        }
        
        // Handle rgb() format
        if (hex.StartsWith("rgb("))
        {
            return hex.Replace("rgb(", "").Replace(")", "");
        }
        
        try
        {
            if (hex.Length == 6)
            {
                int r = Convert.ToInt32(hex.Substring(0, 2), 16);
                int g = Convert.ToInt32(hex.Substring(2, 2), 16);
                int b = Convert.ToInt32(hex.Substring(4, 2), 16);
                return $"{r}, {g}, {b}";
            }
            else if (hex.Length == 3)
            {
                int r = Convert.ToInt32(hex.Substring(0, 1) + hex.Substring(0, 1), 16);
                int g = Convert.ToInt32(hex.Substring(1, 1) + hex.Substring(1, 1), 16);
                int b = Convert.ToInt32(hex.Substring(2, 1) + hex.Substring(2, 1), 16);
                return $"{r}, {g}, {b}";
            }
        }
        catch
        {
            return "145, 0, 18"; // Fallback on error
        }
        
        return "145, 0, 18"; // Default fallback
    }
    
    // Helper method to darken a color for gradient effects
    private string DarkenColor(string hex)
    {
        if (string.IsNullOrEmpty(hex))
            return "#b30015"; // Default fallback
            
        // If already rgba/rgb, return darker version
        if (hex.StartsWith("rgba(") || hex.StartsWith("rgb("))
            return hex; // Can't easily darken rgba/rgb strings, return as-is
            
        hex = hex.Replace("#", "");
        
        try
        {
            if (hex.Length == 6)
            {
                int r = Convert.ToInt32(hex.Substring(0, 2), 16);
                int g = Convert.ToInt32(hex.Substring(2, 2), 16);
                int b = Convert.ToInt32(hex.Substring(4, 2), 16);
                
                // Darken by 20%
                r = (int)(r * 1.2);
                g = (int)(g * 1.2);
                b = (int)(b * 1.2);
                
                // Clamp values
                r = Math.Min(255, r);
                g = Math.Min(255, g);
                b = Math.Min(255, b);
                
                return $"#{r:X2}{g:X2}{b:X2}";
            }
        }
        catch
        {
            return "#b30015"; // Fallback on error
        }
        
        return "#b30015"; // Default fallback
    }

    #region Version Check Timer

    private System.Threading.Timer? _versionCheckTimer;

    private void StartVersionCheckTimer()
    {
        // Start periodic version check every 60 minutes
        _versionCheckTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                var versionCheck = await Classes.Members_Portal.VersionCheck.CheckVersionAsync();

                if (versionCheck != null)
                {
                    // Update UI state
                    _updateAvailable = versionCheck.IsOutdated;
                    _updateForceRequired = versionCheck.RequiresForceUpdate;
                    _latestVersion = versionCheck.LatestVersion;
                    _daysSinceRelease = versionCheck.DaysSinceRelease;

                    if (versionCheck.RequiresForceUpdate)
                    {
                        await InvokeAsync(() =>
                        {
                            NavigationManager.NavigateTo("/update-required", true);
                        });
                    }
                    else
                    {
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }
            catch (Exception ex)
            {
                Logging.Handler.Error("MainLayout.VersionCheckTimer", "Error", ex.ToString());
            }
        }, null, TimeSpan.FromMinutes(60), TimeSpan.FromMinutes(60));
    }

