    // Seasonal Event Enum
    private enum SeasonalEvent
    {
        None,
        WinterSnowfall,      // December 10 - February 28
        NewYearFireworks,    // December 28 - January 3 (Silvester/New Year)
        Valentine,           // February 10-14
        Easter,              // Easter week (calculated)
        Spring,              // March 20 - June 20
        Halloween,           // October 15 - November 1
        Autumn               // September 22 - December 9
    }

    //OSSCH_START 891369a5-26fd-449e-a2f0-d97c7439783d //OSSCH_END
    
    private SeasonalEvent DetectSeasonalEvent()
    {
        var now = DateTime.Now;
        int month = now.Month;
        int day = now.Day;

        // New Year / Silvester (highest priority)
        if ((month == 12 && day >= 28) || (month == 1 && day <= 3))
            return SeasonalEvent.NewYearFireworks;

        // Valentine's Day
        if (month == 2 && day >= 10 && day <= 14)
            return SeasonalEvent.Valentine;

        // Easter (around Easter Sunday - simplified: April)
        if (month == 4 && day >= 10 && day <= 20)
            return SeasonalEvent.Easter;

        // Halloween
        if ((month == 10 && day >= 15) || (month == 11 && day == 1))
            return SeasonalEvent.Halloween;

        // Winter Snowfall (December-February, but not during New Year)
        if (month == 12 || month == 1 || month == 2)
            return SeasonalEvent.WinterSnowfall;

        // Spring
        if (month >= 3 && month <= 5)
            return SeasonalEvent.Spring;

        // Autumn
        if (month >= 9 && month <= 11)
            return SeasonalEvent.Autumn;

        return SeasonalEvent.None;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();

            await Permissions();
            
            StateHasChanged();

            //await Check_Server_Health(); // Needs rewrite

            // Check for updates on application start
            await CheckUpdateAvailability();

            // Start periodic version check timer (every 60 minutes)
            StartVersionCheckTimer();
        }
    }

    private string GetUpdateTooltipText()
    {
        return $"Update available: v{_latestVersion} (released {_daysSinceRelease} days ago)";
    }

    private bool _isCheckingUpdate = false;

    private async Task CheckUpdateAvailability()
    {
        // Prevent concurrent checks
        if (_isCheckingUpdate)
            return;

        // Don't check if we're already on the update-required page
        if (NavigationManager.Uri.Contains("/update-required"))
            return;

        _isCheckingUpdate = true;

        try
        {
            var versionCheck = await Classes.Members_Portal.VersionCheck.CheckVersionAsync();

            if (versionCheck != null)
            {
                // Only update state if values changed
                bool stateChanged = _updateAvailable != versionCheck.IsOutdated ||
                                    _updateForceRequired != versionCheck.RequiresForceUpdate ||
                                    _latestVersion != versionCheck.LatestVersion ||
                                    _daysSinceRelease != versionCheck.DaysSinceRelease;

                _updateAvailable = versionCheck.IsOutdated;
                _updateForceRequired = versionCheck.RequiresForceUpdate;
                _latestVersion = versionCheck.LatestVersion;
                _daysSinceRelease = versionCheck.DaysSinceRelease;

                // Redirect to update-required page if force update is needed (and not already there)
                if (versionCheck.RequiresForceUpdate)
                {
                    NavigationManager.NavigateTo("/update-required", true);
                    return;
                }

                if (stateChanged)
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (Exception ex)
        {
            Logging.Handler.Error("MainLayout.CheckUpdateAvailability", "Error", ex.ToString());
        }
        finally
        {
            _isCheckingUpdate = false;
        }
    }
   
